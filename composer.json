{
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.5.0",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "symfony/console": ">=8.0.13",
        "symfony/dotenv": ">=8.0.11",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": ">=8.0.13",
        "symfony/http-client": ">=8.0.13",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/runtime": ">=8.0.13",
        "symfony/twig-bundle": ">=8.0.8",
        "symfony/yaml": ">=8.0.13"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1.13",
        "symfony/browser-kit": ">=8.0.8",
        "symfony/css-selector": ">=8.0.9",
        "symfony/debug-bundle": ">=8.0.8",
        "symfony/maker-bundle": "^v1.67.0",
        "symfony/stopwatch": ">=8.0.8",
        "symfony/web-profiler-bundle": ">=8.0.13"
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "paragonie/random_compat": "2.*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*"
    },
    "scripts": {
        "symfony-scripts": [
            "rm -rf var/cache/*",
            "bin/console assets:install public --relative"
        ],
        "post-install-cmd": [
            "@symfony-scripts"
        ],
        "post-update-cmd": [
            "@symfony-scripts"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "ckeditor:install": "symfony-cmd"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "discard-changes" : true,
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*"
        }
    }
}
